{
  "ai": {
    "local_model": "llama3.1:8b",
    "local_url": "http://localhost:11434",
    "cloud_model": "claude-haiku-4-5-20251001",
    "use_local_first": true,
    "local_timeout": 30
  },
  "voice": {
    "tts_engine": "edge-tts",
    "voice": "it-IT-DiegoNeural",
    "music_full_volume": 0.85,
    "music_duck_volume": 0.15,
    "music_file": "backInBlack.mp3"
  },
  "paths": {
    "chroma_db": "chroma_db",
    "music": "backInBlack.mp3",
    "screenshots": "screenshots",
    "docs_folder": "docs"
  },
  "system": {
    "max_tokens": 1024,
    "temperature": 0.7,
    "response_timeout": 30
  },
  "features": {
    "enable_rag": true,
    "enable_web_search": true,
    "enable_pc_control": true,
    "enable_finance_tracker": true,
    "enable_alexa": false
  }
}
